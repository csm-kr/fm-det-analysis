# fm-det 환경변수 예시 — `.env` 로 복사 후 값 채우기 (`.env` 는 .gitignore).
#   cp .env.example .env

# ─── Git identity (entrypoint 가 컨테이너 git config 에 자동 주입) ───
GIT_USER_NAME=
GIT_USER_EMAIL=

# ─── 호스트 UID/GID — bind 마운트 권한 일치 ───
# 호스트에서: id -u (UID), id -g (GID) 결과를 입력
# 기본값 1000 이 호스트와 다르면 컨테이너 안에서 .claude / runs/ 권한 깨짐 가능
HOST_UID=1000
HOST_GID=1000

# ─── Weights & Biases (병행 추적 — 첫 도입) ───
# 1. https://wandb.ai 가입
# 2. https://wandb.ai/authorize 에서 API key 발급 후 아래에 붙여넣기
# 3. 익숙해질 때까지는 WANDB_MODE=offline 권장 (학습 종료 후 `wandb sync` 로 업로드)
WANDB_API_KEY=
WANDB_MODE=offline

# ─── Hydra ───
HYDRA_FULL_ERROR=1

# ─── 참고 — 자세한 사용법 ───
# docs/HYDRA_GUIDE.md  : Hydra 첫 도입자 학습 자료
# docs/WANDB_GUIDE.md  : W&B 첫 도입자 학습 자료
# docs/EXPERIMENTS.md  : 실험 1회의 완료 정의 5단계
