  "hypothesis": null,
  "baseline_run_id": null,
  "eval_spec": {
    "task": "detection",
    "metric_primary": "n/a",
    "metric_lib": "pycocotools==2.0.7",
    "input_format": { "pred": "n/a", "gt": "xyxy_class" },
    "success_threshold": null
  },
  "scope": {
    "dataset": "COCO 2017",
